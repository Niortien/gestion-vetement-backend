generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String           @id @default(uuid())
  email        String           @unique
  passwordHash String
  role         UserRole         @default(VENDEUR)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  entrees      Entree[]
  mouvements   MouvementStock[]
  sessions     Session[]
  sorties      Sortie[]
}

model Categorie {
  id          String    @id @default(uuid())
  nom         String
  slug        String    @unique
  description String?
  produits    Produit[]
}

model Produit {
  id          String         @id @default(uuid())
  nom         String
  sku         String         @unique
  description String?
  categorieId String
  prixVente   Decimal        @db.Decimal(10, 2)
  prixAchat   Decimal        @db.Decimal(10, 2)
  imageUrl    String?
  isActif     Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  categorie   Categorie      @relation(fields: [categorieId], references: [id])
  variantes   Variante[]
  images      ProduitImage[]
}

model ProduitImage {
  id        String   @id @default(uuid())
  produitId String
  url       String
  ordre     Int      @default(0)
  createdAt DateTime @default(now())
  produit   Produit  @relation(fields: [produitId], references: [id], onDelete: Cascade)
}

model Variante {
  id            String           @id @default(uuid())
  produitId     String
  taille        String
  couleur       String
  quantiteStock Int
  seuilAlerte   Int
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  lignesEntree  LigneEntree[]
  lignesSortie  LigneSortie[]
  mouvements    MouvementStock[]
  produit       Produit          @relation(fields: [produitId], references: [id])

  @@unique([produitId, taille, couleur])
}

model MouvementStock {
  id              String             @id @default(uuid())
  varianteId      String
  type            TypeMouvementStock
  quantite        Int
  motif           String?
  referenceEntree String?
  referenceSortie String?
  userId          String
  createdAt       DateTime           @default(now())
  user            User               @relation(fields: [userId], references: [id])
  variante        Variante           @relation(fields: [varianteId], references: [id])
}

model Entree {
  id          String        @id @default(uuid())
  reference   String        @unique
  fournisseur String
  totalCout   Decimal       @db.Decimal(10, 2)
  notes       String?
  userId      String
  createdAt   DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id])
  lignes      LigneEntree[]
}

model LigneEntree {
  id           String   @id @default(uuid())
  entreeId     String
  varianteId   String
  quantite     Int
  prixUnitaire Decimal  @db.Decimal(10, 2)
  entree       Entree   @relation(fields: [entreeId], references: [id], onDelete: Cascade)
  variante     Variante @relation(fields: [varianteId], references: [id])
}

model Sortie {
  id            String        @id @default(uuid())
  reference     String        @unique
  type          TypeSortie
  totalMontant  Decimal       @db.Decimal(10, 2)
  notes         String?
  userId        String
  transactionId String?
  createdAt     DateTime      @default(now())
  lignes        LigneSortie[]
  user          User          @relation(fields: [userId], references: [id])
}

model LigneSortie {
  id           String   @id @default(uuid())
  sortieId     String
  varianteId   String
  quantite     Int
  prixUnitaire Decimal  @db.Decimal(10, 2)
  sortie       Sortie   @relation(fields: [sortieId], references: [id], onDelete: Cascade)
  variante     Variante @relation(fields: [varianteId], references: [id])
}

model Session {
  id               String              @id @default(uuid())
  userId           String
  dateOuverture    DateTime
  dateFermeture    DateTime?
  montantOuverture Decimal             @db.Decimal(10, 2)
  montantFermeture Decimal?            @db.Decimal(10, 2)
  statut           StatutSessionCaisse
  user             User                @relation(fields: [userId], references: [id])
  transactions     Transaction[]
}

model Transaction {
  id           String       @id @default(uuid())
  sessionId    String
  sortieId     String?      @unique
  montant      Decimal      @db.Decimal(10, 2)
  modePaiement ModePaiement
  reference    String?
  notes        String?
  createdAt    DateTime     @default(now())
  session      Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

enum UserRole {
  ADMIN
  VENDEUR
}

enum TypeMouvementStock {
  ENTREE
  SORTIE
  AJUSTEMENT
  RETOUR
}

enum TypeSortie {
  VENTE
  PERTE
  DON
  RETOUR_FOURNISSEUR
}

enum StatutSessionCaisse {
  OUVERTE
  FERMEE
}

enum ModePaiement {
  CASH
  WAVE
  ORANGE_MONEY
  CARTE
  MTN_MONEY
}
